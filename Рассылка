async def cmd_listchat(interaction: discord.Interaction):
    excluded = bot.get_excluded(interaction.guild.id)
    em = bot.embed(
        "info",
        f"{E['settings']} Управление каналами",
        f"Выберите каналы в меню ниже.\n"
        f"• Если канал **не исключён** — он будет исключён\n"
