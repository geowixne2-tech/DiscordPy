# ============ СЛЭШ КОМАНДА ПРОСТОГО КАЛЬКУЛЯТОРА ============
@bot.tree.command(name="calc", description="Вычислить математическое выражение")
@app_commands.describe(выражение="Пример: 2+2 или 10*5-3")
async def calculator(interaction: discord.Interaction, выражение: str):
    """Простой калькулятор"""
    try:
        # Очистка выражения
        выражение = выражение.replace(' ', '')
        
        # Белый список допустимых символов
        if not re.match(r'^[0-9+\-*/().pi]+$', выражение):
            raise ValueError("Содержит недопустимые символы")
        
        # Безопасное вычисление
        allowed_functions = {
            'abs': abs,
            'round': round,
            'max': max,
            'min': min,
            'pow': pow,
            'sqrt': math.sqrt,
            'sin': math.sin,
            'cos': math.cos,
            'tan': math.tan,
            'pi': math.pi,
            'e': math.e
        }
        
        result = eval(выражение, {"__builtins__": {}}, allowed_functions)
        
        # Округляем до 10 знаков после запятой
        if isinstance(result, float):
            result = round(result, 10)
        
        embed = discord.Embed(
            title="🧮 Результат",
            color=discord.Color.green(),
            description=f"**Выражение:** `{выражение}`\n**Ответ:** `{result}`"
        )
        
        await interaction.response.send_message(embed=embed)
        
    except ZeroDivisionError:
        await interaction.response.send_message(
            embed=discord.Embed(title="❌ Ошибка", 
            description="Деление на ноль!", 
            color=discord.Color.red())
        )
    except Exception as e:
        await interaction.response.send_message(
            embed=discord.Embed(title="❌ Ошибка", 
            description=f"Неверное выражение: {str(e)}", 
            color=discord.Color.red())
        )

# ============ ИНТЕРАКТИВНЫЙ КАЛЬКУЛЯТОР С КНОПКАМИ ============
class CalculatorView(discord.ui.View):
    def __init__(self):
        super().__init__(timeout=300)
        self.expression = "0"
        self.update_display()
    
    def update_display(self):
        """Обновляет текст кнопки Display"""
        display_text = self.expression if len(self.expression) <= 20 else self.expression[-20:]
        for item in self.children:
            if hasattr(item, 'custom_id') and item.custom_id == 'display':
                item.label = display_text
                break
    
    def add_to_expression(self, value: str):
        """Добавить значение к выражению"""
        if self.expression == "0":
            self.expression = value
        else:
            self.expression += value
        self.update_display()
    
    def calculate(self):
        """Вычислить результат"""
        try:
            allowed = {
                'abs': abs, 'round': round, 'max': max, 'min': min,
                'pow': pow, 'sqrt': math.sqrt, 'sin': math.sin,
                'cos': math.cos, 'tan': math.tan, 'pi': math.pi, 'e': math.e
            }
            result = eval(self.expression, {"__builtins__": {}}, allowed)
            if isinstance(result, float):
                result = round(result, 10)
            self.expression = str(result)
        except:
            self.expression = "Ошибка"
        self.update_display()
    
    # Первая строка (1-3)
    @discord.ui.button(label="1", style=discord.ButtonStyle.gray, row=1)
    async def btn_1(self, interaction: discord.Interaction, button: discord.ui.Button):
        self.add_to_expression("1")
        await interaction.response.defer()
    
    @discord.ui.button(label="2", style=discord.ButtonStyle.gray, row=1)
    async def btn_2(self, interaction: discord.Interaction, button: discord.ui.Button):
