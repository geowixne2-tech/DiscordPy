            self.expression = self.expression[:-1]
        else:
            self.expression = "0"
        self.update_display()
        await interaction.response.defer()
    
    @discord.ui.button(label="()", style=discord.ButtonStyle.gray, row=5)
    async def btn_brackets(self, interaction: discord.Interaction, button: discord.ui.Button):
        self.add_to_expression("()")
        await interaction.response.defer()
    
    @discord.ui.button(label="Display", style=discord.ButtonStyle.gray, disabled=True, custom_id='display', row=0)
    async def display(self, interaction: discord.Interaction, button: discord.ui.Button):
        pass

