import discord
from discord.ext import commands
import json
import random
import os


class LoreBot(commands.Bot):
    def __init__(self):
        intents = discord.Intents.default()
        intents.members = True
        intents.message_content = True
        super().__init__(command_prefix="!", intents=intents)

        self.lore_file = "lore_data.json"
        self.default_lore = [
            "⚔️ Ветер шепнул имя **{user}** в древних руинах...",
            "🔥 Свет факелов озарил лицо **{user}**...",
            "📜 Пророчество гласит: **{user}** пришёл сменить судьбу...",
            "🌍 Земля дрогнула, когда **{user}** шагнул на священную землю...",
            "⭐ Звёзды переплелись, обозначив путь **{user}**...",
            "👑 Трон ждал **{user}** — пришёл правитель...",
            "🌑 Тени склонились перед **{user}**...",
            "🗡️ Клинок пробудился от присутствия **{user}**...",
            "🐉 Древний дракон открыл глаза — **{user}** приближается...",
            "🌊 Волны шепчут: **{user}** — избранный моря...",
        ]
        self.data = self.load_data()

    def load_data(self):
        if os.path.exists(self.lore_file):
            with open(self.lore_file, "r", encoding="utf-8") as f:
                return json.load(f)
        return {"lore": self.default_lore.copy(), "channel": None}

    def save_data(self):
        with open(self.lore_file, "w", encoding="utf-8") as f:
            json.dump(self.data, f, ensure_ascii=False, indent=2)

    def get_lore(self):
        return self.data.get("lore", self.default_lore)

    def get_channel(self):
        return self.data.get("channel")

    async def setup_hook(self):
        await self.tree.sync()
        print(f"✅ {self.user} готов!")


bot = LoreBot()


# ===== Событие: вход участника =====
@bot.event
async def on_member_join(member):
    cid = bot.get_channel()
    if not cid:
        return

    channel = bot.get_channel(cid)
    if not channel:
        return

    lore = random.choice(bot.get_lore()).format(user=member.mention)

    embed = discord.Embed(description=f"📜 *{lore}*", color=discord.Color.gold())
    embed.set_thumbnail(url=member.display_avatar.url)
    embed.set_footer(text=f"Добро пожаловать, {member.name}!")

    await channel.send(embed=embed)


# ===== /chats =====
@bot.tree.command(name="chats", description="📌 Канал для lore")
async def chats(interaction: discord.Interaction, channel: discord.TextChannel):
    bot.data["channel"] = channel.id
    bot.save_data()
    await interaction.response.send_message(
        embed=discord.Embed(
            title="✅ Установлено", description=f"Lore → {channel.mention}", color=discord.Color.green()
        )
    )


# ===== /addlore =====
@bot.tree.command(name="addlore", description="📝 Добавить lore")
async def addlore(interaction: discord.Interaction, text: str):
    if len(text) > 500:
        return await interaction.response.send_message("❌ Макс 500 символов", ephemeral=True)
    bot.data.setdefault("lore", []).append(text)
    bot.save_data()
    await interaction.response.send_message(
        embed=discord.Embed(
            title="✅ Добавлено", description=f"```{text}```", color=discord.Color.green()
        ).set_footer(text=f"Всего: {len(bot.data['lore'])}")
    )


# ===== /removelore =====
@bot.tree.command(name="removelore", description="🗑️ Удалить lore по номеру")
async def removelore(interaction: discord.Interaction, number: int):
    lore = bot.data.get("lore", [])
    if number < 1 or number > len(lore):
        return await interaction.response.send_message(f"❌ Нет #{number}", ephemeral=True)
    removed = lore.pop(number - 1)
    bot.save_data()
    await interaction.response.send_message(
        embed=discord.Embed(title="🗑️ Удалено", description=removed, color=discord.Color.red())
    )


# ===== /listlore =====
@bot.tree.command(name="listlore", description="📋 Все lore")
async def listlore(interaction: discord.Interaction):
    lore = bot.get_lore()
    text = "\n".join(f"**{i+1}.** {t}" for i, t in enumerate(lore))
    await interaction.response.send_message(
        embed=discord.Embed(title=f"📜 ({len(lore)})", description=text[:4096], color=discord.Color.purple())
    )


# ===== /testlore =====
@bot.tree.command(name="testlore", description="🧪 Тест lore")
async def testlore(interaction: discord.Interaction):
    cid = bot.get_channel()
    if not cid:
        return await interaction.response.send_message("❌ Сначала /chats", ephemeral=True)
    channel = bot.get_channel(cid)
    lore = random.choice(bot.get_lore()).format(user=interaction.user.mention)
    embed = discord.Embed(description=f"📜 *{lore}* ⚡*(тест)*", color=discord.Color.orange())
    embed.set_thumbnail(url=interaction.user.display_avatar.url)
    await channel.send(embed=embed)
    await interaction.response.send_message("✅ Отправлено!", ephemeral=True)


# ===== Запуск =====
bot.run("YOUR_TOKEN")
